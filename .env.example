# Compose reads `.env` from the repo root. Copy this to `.env` and fill it in:
#
#   cp .env.example .env
#
# Every value below is a secret. Generate each one separately:
#
#   openssl rand -base64 32
#
# This file is only for `docker compose`. Running the apps directly uses the
# per-app files instead — apps/backend/.env and apps/{web,admin}/.env.local.

# Encrypts OAuth provider tokens at rest (backend).
DATA_ENCRYPTION_KEY=

# Shared between the frontends and the backend: it authenticates the
# /v1/auth/exchange call that turns a Google identity into a backend token.
# Anyone holding it can mint a session for any email — treat it accordingly.
AUTH_EXCHANGE_SECRET=

# Signs the NextAuth session cookie (web + admin).
AUTH_SECRET=

# Optional — the seeded SUPER_ADMIN. Change the password before exposing anything.
# ADMIN_EMAIL=admin@example.com
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=ChangeMe123!

# Optional — Postgres. Defaults are fine for local work.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=groundwork
# POSTGRES_PORT=5432
