{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "openapi": {
      "inputs": ["src/**/*.ts", "scripts/**/*.ts"],
      "outputs": ["openapi.json", "dist/**"]
    },
    "generate": {
      "dependsOn": ["backend#openapi"],
      "inputs": ["../../apps/backend/openapi.json"],
      "outputs": ["src/schema.d.ts"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "src/schema.d.ts"]
    },
    "@workspace/api-client#build": {
      "dependsOn": ["backend#openapi"],
      "inputs": ["src/**", "../../apps/backend/openapi.json"],
      "outputs": ["src/schema.d.ts"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
