# Copy to .env.local and fill in. `.env.local` is git-ignored — never commit it.

# NestJS backend base (server-side only). Must include the /v1 prefix.
API_URL="http://localhost:9000/v1"

# next-auth. Generate the secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"

# Shared secret for POST /v1/auth/exchange. Must match the backend's value.
AUTH_EXCHANGE_SECRET="local-auth-exchange-secret-please-change"
