# Copy to .env and fill in. `.env` is git-ignored — never commit it.

NODE_ENV=development
PORT=9000

# If you already run Postgres natively on 5432, set POSTGRES_PORT to a free port
# (docker-compose reads it) and change the port here to match.
# POSTGRES_PORT=5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/groundwork"

# RSA keypair for signing access tokens. Generate both with: bun run keys:generate
JWT_PRIVATE_KEY_PATH="./keys/private.pem"
JWT_PUBLIC_KEY_PATH="./keys/public.pem"

# Shared only between Next.js server code and this API — it guards POST /v1/auth/exchange.
# Must match AUTH_EXCHANGE_SECRET in apps/web and apps/admin.
AUTH_EXCHANGE_SECRET="replace-with-a-long-random-secret"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS allowlist. Unset means cross-origin requests are denied (it does not fall open to *).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Application data encryption (AES-256-GCM). Generate: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# Seed admin — used by `bun run db:seed`
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# --- Storage -----------------------------------------------------------------
# `local` writes uploads to disk and needs no cloud account. This is the default,
# and it is what lets a fresh clone run with nothing but Postgres.
FILES_DRIVER=local
LOCAL_STORAGE_DIR=./storage

# Required ONLY when FILES_DRIVER=s3:
AWS_REGION=
ASSETS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
# Signing key — supply EITHER of these (B64 wins if both are set):
CLOUDFRONT_PRIVATE_KEY_PATH=./keys/cloudfront_private_key.pem
CLOUDFRONT_PRIVATE_KEY_B64=
DATA_ENCRYPTION_KMS_KEY_ARN=

# Assets referenced by nothing and older than this are swept daily.
FILE_ORPHAN_TTL_HOURS=24

# --- Transactional email -----------------------------------------------------
# `log` renders the email to the server log — no API key, no network. Use `brevo` in prod.
MAIL_TRANSPORT=log
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=Groundwork
# Base URL of the web app — used to build password-reset links.
APP_WEB_URL=http://localhost:3000
