  "info": {
    "title": "Groundwork API",
    "description": "Fullstack boilerplate API — authentication, RBAC, file uploads, audit log, and transactional email.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "John Doe",
            "description": "Display name of the user",
            "minLength": 2,
            "maxLength": 60,
            "pattern": "^[A-Za-z]+(?:[ '-][A-Za-z]+)*$"
          },
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "The email of the user"
          },
          "avatar": {
            "type": "string",
            "example": "https://cdn.example.com/avatars/jane.png",
            "description": "Optional avatar URL for the user"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "The password for the user",
            "minLength": 8
          }
        },
        "required": [
          "username",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email address of the user"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "The password for the user"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Opaque token from the reset link"
          },
          "newPassword": {
            "type": "string",
            "example": "newPassword123",
            "minLength": 8
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "ExchangeAuthDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "example": "google",
            "description": "External identity provider name from Auth.js"
          },
          "providerAccountId": {
            "type": "string",
            "example": "109876543210987654321",
            "description": "Stable provider account identifier"
          },
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Verified email address from the identity provider"
          },
          "username": {
            "type": "string",
            "example": "Jane Tester",
            "description": "Display name from the provider profile",
            "minLength": 2,
            "maxLength": 60
          },
          "avatar": {
            "type": "string",
            "example": "https://lh3.googleusercontent.com/a/avatar",
            "description": "Optional avatar URL from the provider profile"
          },
          "emailVerifiedAt": {
            "type": "string",
            "example": "2026-04-04T08:00:00.000Z",
            "description": "Provider verified-email timestamp in ISO format"
          },
          "accessToken": {
            "type": "string",
            "example": "ya29.a0AfH6SMA...",
            "description": "Optional provider access token for future API calls"
          },
          "refreshToken": {
            "type": "string",
            "example": "1//0gRefreshToken",
            "description": "Optional provider refresh token"
          },
          "idToken": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6IjEifQ...",
            "description": "Optional provider ID token"
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer",
            "description": "Provider token type"
          },
          "scope": {
            "type": "string",
            "example": "openid email profile",
            "description": "Granted provider scopes"
          },
          "expiresAt": {
            "type": "number",
            "example": 1743753600,
            "description": "Access token expiry timestamp in seconds"
          }
        },
        "required": [
          "provider",
          "providerAccountId",
          "email",
          "username",
          "emailVerifiedAt"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9...",
            "description": "Previously issued refresh token"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "CreateStaffDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "staff@acme.example"
          },
          "username": {
            "type": "string",
            "example": "Jane Agent"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          },
          "roles": {
            "type": "array",
            "example": [
              "EDITOR"
            ],
            "items": {
              "type": "string",
              "enum": [
                "SUPER_ADMIN",
                "ADMIN",
                "EDITOR",
                "VIEWER",
                "USER"
              ]
            }
          }
        },
        "required": [
          "email",
          "username",
          "password",
          "roles"
        ]
      },
      "UpdateStaffRolesDto": {
        "type": "object",
        "properties": {
          "roles": {
            "type": "array",
            "example": [
              "ADMIN"
            ],
            "items": {
              "type": "string",
              "enum": [
                "SUPER_ADMIN",
                "ADMIN",
                "EDITOR",
                "VIEWER",
                "USER"
              ]
            }
          }
        },
        "required": [
          "roles"
        ]
      },
      "CreateUploadDto": {
        "type": "object",
        "properties": {
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ],
            "example": "public"
          },
          "kind": {
            "type": "string",
            "example": "item",
            "description": "Logical group: item|avatar|banner|document|misc",
            "enum": [
              "item",
              "avatar",
              "banner",
              "document",
              "misc"
            ]
          },
          "filename": {
            "type": "string",
            "example": "galle-front.jpg"
          },
          "contentType": {
            "type": "string",
            "example": "image/jpeg"
          }
        },
        "required": [
          "visibility",
          "kind",
          "filename",
          "contentType"
        ]
      },
      "CreateItemDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "My first item"
          },
          "description": {
            "type": "string",
            "example": "A longer description of the item."
          },
          "published": {
            "type": "boolean",
            "default": false
          },
          "imageFileIds": {
            "description": "FileAsset ids from POST /v1/admin/files/uploads",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateItemDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "My first item"
          },
          "description": {
            "type": "string",
            "example": "A longer description of the item."
          },
          "published": {
            "type": "boolean",
            "default": false
          },
          "imageFileIds": {
            "description": "FileAsset ids from POST /v1/admin/files/uploads",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
