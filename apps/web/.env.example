# Copy to .env.local and fill in. `.env.local` is git-ignored — never commit it.

# NestJS backend base (server-side only — never exposed to the browser).
# Must include the /v1 version prefix and match the backend's actual PORT.
API_URL="http://localhost:9000/v1"

# next-auth. Generate the secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth web client (Google Cloud console). Optional locally — without these
# the "Continue with Google" button won't work, but email/password login still does.
# Add the redirect URI {AUTH_URL}/api/auth/callback/google to the OAuth client.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Shared secret for trading a Google identity for backend tokens at POST /v1/auth/exchange.
# MUST be identical to the backend's AUTH_EXCHANGE_SECRET.
AUTH_EXCHANGE_SECRET="local-auth-exchange-secret-please-change"
